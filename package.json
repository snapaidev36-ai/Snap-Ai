{
  "name": "snap-ai",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c yellow,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
